---
import GithubIcon from "./icons/GithubIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
import KaggleIcon from "./icons/KaggleIcon.astro";
import InstagramIcon from "./icons/InstagramIcon.astro";
---

<footer id="main-footer">
    <div class="container footer-container">
        <p class="footer-copyright">&copy; 2025 Erik Ramirez.</p>
        <p class="footer-quote">
            "Creando el futuro, una línea de código a la vez."
        </p>
        <div class="footer-socials">
            <a
                href="https://linkedin.com/in/xerikrz"
                target="_blank"
                aria-label="LinkedIn"><LinkedInIcon /></a
            >
            <a
                href="https://github.com/xerikrz"
                target="_blank"
                aria-label="GitHub"><GithubIcon /></a
            >
            <a
                href="https://www.kaggle.com/xerikrz"
                target="_blank"
                aria-label="Kaggle"><KaggleIcon /></a
            >
            <a
                href="https://instagram.com/xerikrz"
                target="_blank"
                aria-label="Instagram"><InstagramIcon /></a
            >
        </div>
    </div>
</footer>

<style is:global>
    #main-footer {
        background-color: var(--color-gray-900);
        text-align: center;
        padding: 0.25rem 1rem;
        margin-bottom: 46px;
        color: var(--color-gray-600);
        border-top: 2px solid var(--color-primary);
        font-family: var(--font-secondary);
    }

    .footer-quote {
        margin-top: 1rem;
    }

    @media (min-width: 768px) {
        #main-footer {
            margin-bottom: 0px;
            padding: 2rem 1rem;
        }

        .footer-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .footer-quote {
            margin-top: 0;
        }
    }

    .footer-socials {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }
    @media (min-width: 768px) {
        .footer-socials {
            margin-bottom: 0;
        }
    }

    .footer-socials a {
        color: var(--color-gray-600);
        transition:
            color 0.3s ease,
            transform 0.3s ease;
    }

    .footer-socials a:hover {
        color: var(--color-primary-light);
        transform: scale(1.2);
    }

    .footer-socials svg {
        width: 24px;
        height: 24px;
    }

    .footer-quote {
        font-style: italic;
        margin-bottom: 1.5rem;
        color: var(--color-light);
        font-size: 1rem;
    }
    @media (min-width: 768px) {
        .footer-quote {
            text-align: center;
            margin-bottom: 0;
        }
    }

    .footer-copyright {
        font-size: 0.9rem;
        margin-top: 1rem;
    }
    @media (min-width: 768px) {
        .footer-copyright {
            font-size: 1rem;
            margin-top: 0;
            text-align: left;
        }
    }
    @media (min-width: 1024px) {
        .footer-socials {
            gap: 2rem;
        }
    }
</style>
